<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:padding="16dp" android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
        <Spinner android:id="@+id/spFoods" android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <EditText android:id="@+id/etQty" android:hint="Quantity (servings)" android:inputType="numberDecimal" android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <Spinner android:id="@+id/spMealType" android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <EditText android:id="@+id/etNotes" android:hint="Notes (optional)" android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <Button android:id="@+id/btnAddMeal" android:text="Add Meal" android:layout_marginTop="12dp" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </LinearLayout>
</ScrollView>
