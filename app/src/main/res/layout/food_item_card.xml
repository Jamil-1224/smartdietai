<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Food Name and Serving -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/food_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Food Name"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"/>

            <TextView
                android:id="@+id/food_serving"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100g"
                android:textSize="13sp"
                android:textColor="#757575"
                android:background="#E8F5E9"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Nutrition Table Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F1F8E9"
            android:padding="6dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Calories"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#558B2F"
                android:gravity="center"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Protein"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#558B2F"
                android:gravity="center"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Carbs"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#558B2F"
                android:gravity="center"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Fat"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#558B2F"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Nutrition Table Values -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="6dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/food_calories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="130"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#F57C00"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="kcal"
                    android:textSize="10sp"
                    android:textColor="#9E9E9E"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/food_protein"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6.0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2196F3"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="g"
                    android:textSize="10sp"
                    android:textColor="#9E9E9E"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/food_carbs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="28.0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="g"
                    android:textSize="10sp"
                    android:textColor="#9E9E9E"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/food_fat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.3"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#9C27B0"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="g"
                    android:textSize="10sp"
                    android:textColor="#9E9E9E"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Long Press Hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Long press to delete"
            android:textSize="9sp"
            android:textColor="#B0BEC5"
            android:gravity="end"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-light"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>

